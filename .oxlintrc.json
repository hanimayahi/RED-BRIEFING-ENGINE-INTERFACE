{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "oxc", "import", "vitest", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error"
  },
  "rules": {
    "no-console": "error",
    "no-debugger": "error",
    "eqeqeq": "error",
    "import/no-duplicates": "error",
    "import/no-unassigned-import": "off",
    "typescript/no-explicit-any": "error"
  }
}
